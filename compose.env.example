# Copy this file to .env before running `docker compose up --build`.

# Publish only to loopback by default. Use 0.0.0.0 when a reverse proxy or
# trusted network needs to reach the container directly.
KNIVES_OUT_BIND_HOST=127.0.0.1
KNIVES_OUT_PORT=8787

# The app stores project state, runs, and artifacts here inside the container.
KNIVES_OUT_API_DATA_DIR=/var/lib/knives-out

# Set both values to enable browser-level HTTP Basic auth for `/`, `/app/*`,
# `/v1/*`, `/docs`, and `/openapi.json`.
KNIVES_OUT_BASIC_AUTH_USERNAME=demo
KNIVES_OUT_BASIC_AUTH_PASSWORD=change-me-before-exposing

# Leave blank for the same-origin container deployment. Only set this when you
# intentionally split the frontend and API across origins.
KNIVES_OUT_CORS_ALLOW_ORIGINS=
